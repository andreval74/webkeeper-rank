# Postgres gerenciado (Neon) — obtenha em https://console.neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Redis gerenciado (Upstash) — obtenha em https://console.upstash.com (opcional na fase inicial)
REDIS_URL=""

# Segredo usado para assinar tokens JWT — gere um valor aleatório forte
JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"

PORT=3333
FRONTEND_URL="http://localhost:3000"
