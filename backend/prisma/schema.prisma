generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companies CompanyMember[]
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  CompanyMember[]
  projects Project[]
}

model CompanyMember {
  id        String   @id @default(cuid())
  role      String   @default("owner")
  userId    String
  companyId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
}

model Project {
  id        String   @id @default(cuid())
  domain    String
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company         @relation(fields: [companyId], references: [id])
  metrics Metric[]
  scores  CategoryScore[]
  geoScores GeoScore[]
  aeoScores AeoScore[]
  brandScores BrandScore[]
  authorityScores AuthorityScore[]
  uxScores UxScore[]
  reputationScores ReputationScore[]
  socialScores SocialScore[]
  localScores LocalScore[]
  conversionScores ConversionScore[]
}

model Metric {
  id        String   @id @default(cuid())
  projectId String
  category  String
  key       String
  value     Float
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model CategoryScore {
  id        String   @id @default(cuid())
  projectId String
  category  String
  score     Float
  breakdown Json
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId, category, createdAt])
}

model GeoScore {
  id        String   @id @default(cuid())
  projectId String
  category  String   @default("GEO")
  score     Float
  breakdown Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, category, createdAt])
}

